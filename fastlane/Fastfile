default_platform(:android)

platform :android do
  lane :github do |options|
    set_github_release(
      repository_name: options[:repository_name],
      api_bearer: options[:api_bearer],
      tag_name: options[:tag_name],
      name: options[:name],
      commitish: options[:commitish],
      is_draft: false,
      upload_assets: ["android-app/build/outputs/apk/release/android-app-release.apk"]
    )
  end

  lane :play do |options|
    upload_to_play_store(
      track: "internal",
      aab: "android-app/build/outputs/bundle/release/android-app-release.aab",
      mapping: "android-app/build/outputs/mapping/release/mapping.txt",
      skip_upload_images: true,
    )
  end
end
